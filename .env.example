# paper or live
TRADING_MODE=paper
ENABLE_LIVE_TRADING=false

# Binance API keys
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Use false to read your real Binance account balance.
# Keep ENABLE_LIVE_TRADING=false unless you intentionally enable real orders.
BINANCE_TESTNET=false

# Use false to show real Binance Spot prices while still paper trading.
MARKET_DATA_TESTNET=false

# Trading setup
SYMBOL=BTCUSDT
INTERVAL=1m
CONFIRM_INTERVAL=5m
LEVERAGE=2

# Risk
MAX_LOSS_USD=5
TARGET_PROFIT_USD=1.0
FEE_RATE=0.0005
DAILY_MAX_LOSS_USD=15
MAX_CONSECUTIVE_LOSSES=3
MIN_SCORE_TO_SHORT=8

# Bot behaviour
LOOP_SECONDS=20
CANDLE_LIMIT=150

# Signal filters
USE_FEAR_GREED_FILTER=true
USE_COINGECKO_FILTER=true
BLOCK_EXTREME_VOLATILITY=true
